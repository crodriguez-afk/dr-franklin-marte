      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-QB27T902DL");
    </script>

		<!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

		<ClientRouter />
		<GTMConsent gtmId="GTM-TN49WM9Q" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Regeneración Articular sin Cirugía | Dr. Franklin Marte Ortopeda</title>
		<meta name="description" content="Tratamientos de regeneración articular sin cirugía para dolor de rodilla, hombro y columna." />

		<meta
      name="keywords"
      content="dr Franklin Marte Gutierrez, Regeneraciones Articulares de hombros, Regeneraciones, Articulares de rodillas, Dolor de columna, Ozonoterapia, dolor de rodilla
"
    />
    <meta name="author" content="Dr. Franklin Marte" />
