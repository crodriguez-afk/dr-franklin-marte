    <link rel="canonical" href="https://drfranklinmartegutierrez.com.do/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://drfranklinmartegutierrez.com.do/" />
    <meta
      property="og:title"
      content="Regeneración Articular sin Cirugía | Dr. Franklin Marte Ortopeda"
    />
    <meta
      property="og:description"
      content="Tratamientos de regeneración articular sin cirugía para dolor de rodilla, hombro y columna. PRP y factores de crecimiento con el Dr. Franklin Marte. Agenda tu consulta."
    />
    <meta
      property="og:image"
      content="https://drfranklinmartegutierrez.com.do/imagen1.JPG"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_DO" />
    <meta property="og:site_name" content="Dr. Franklin Marte" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Regeneración Articular sin Cirugía | Dr. Franklin Marte Ortopeda"
    />
    <meta
      name="twitter:description"
      content="Tratamientos de regeneración articular sin cirugía para dolor de rodilla, hombro y columna. PRP y factores de crecimiento con el Dr. Franklin Marte. Agenda tu consulta."
    />
    <meta
      name="twitter:image"
      content="https://drfranklinmartegutierrez.com.do/imagen1.JPG"
    />
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		
		<style>
			@import "../styles/global.css";

			/* Estilo para asegurar que los iconos SVG locales tengan el color deseado #0794ff */
			.icon-blue {
				filter: invert(48%) sepia(89%) saturate(2831%) hue-rotate(188deg) brightness(101%) contrast(106%);
			}
		</style>
	</head>
	<body class="bg-white antialiased text-[var(--color-text-dark)] font-sans">
		
		<!-- Navegación -->
		<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
			<div class="container-custom h-20 flex items-center justify-between">
				<a href="/" class="flex items-center gap-3">
					<div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center">
						<img src="./icon1-01.svg" alt="Logo Doctor" class="w-6 h-6 icon-blue" />
					</div>
					<div class="flex flex-col">
						<span class="font-bold text-lg leading-none uppercase tracking-tighter">Dr. Franklin Marte</span>
						<span class="text-[10px] font-bold text-[#0794ff] uppercase tracking-widest">Ortopeda Especialista</span>
					</div>
				</a>
				<nav class="hidden md:flex items-center gap-8">
					<a href="#tratamientos" class="text-sm font-medium hover:text-[#0794ff] transition-colors">Tratamientos</a>
					<a href="#doctor" class="text-sm font-medium hover:text-[#0794ff] transition-colors">El Doctor</a>
					<a href="#ubicaciones" class="text-sm font-medium hover:text-[#0794ff] transition-colors">Ubicaciones</a>
					<a href="#agenda" class="btn-primary py-2 px-5 text-sm" style="background-color: #0794ff;">Agenda tu Consulta</a>
				</nav>
			</div>
		</header>

		<main>
			<!-- 🟦 SECCIÓN 1 – REGENERACIÓN ARTICULAR (HERO) -->
			<section class="relative min-h-[90vh] flex items-center bg-[var(--color-light-bg)] overflow-hidden">
				<div class="container-custom py-12 lg:py-20">
					<div class="grid lg:grid-cols-2 gap-12 items-center">
						<div class="z-10">
							<h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6">
								Regeneración Articular sin Cirugía
							</h1>
							<p class="text-xl font-medium text-[#0794ff] mb-4">
								Tratamientos médicos avanzados para el dolor articular
							</p>
							<p class="text-lg text-gray-700 mb-8 leading-relaxed max-w-xl">
								El dolor de rodilla, hombro o columna no siempre debe terminar en cirugía cuando es evaluado por un especialista con un enfoque médico adecuado. El Dr. Franklin Marte se especializa en alternativas no quirúrgicas orientadas a aliviar el dolor y preservar su movilidad.
							</p>
							<div class="flex flex-col sm:flex-row gap-4">
								<a href="#agenda" class="btn-primary text-lg px-10 py-4" style="background-color: #0794ff;">Agenda tu Consulta</a>
								<a href="#tratamientos" class="btn-outline text-lg px-10 py-4" style="border-color: #0794ff; color: #fffff;">Tratamientos sin Cirugía</a>
							</div>
						</div>
						<div class="relative flex justify-center">
							<div class="relative w-full max-w-md aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl border-8 border-white bg-gray-200">
								<!-- Ajustado a .JPG -->
								<img 
									src="./imagen1.JPG" 
									alt="Imagen Principal: Dr. Franklin Marte" 
									class="w-full h-full object-cover block"
									fetchpriority="high"
								/>
							</div>
							<div class="absolute -bottom-6 right-0 bg-white p-4 rounded-xl shadow-lg border border-gray-100 flex items-center gap-3">
								<div class="bg-blue-50 p-2 rounded-full">
									<img src="./icon2.svg" alt="Seguridad" class="w-6 h-6 icon-blue" />
								</div>
								<span class="text-sm font-bold">Enfoque No Quirúrgico</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- 🟦 SECCIÓN 3 – DETALLE DE TRATAMIENTOS -->
			<section id="educativa" class="section-padding bg-[var(--color-light-bg)]">
				<div class="container-custom">
					<div class="grid lg:grid-cols-2 gap-8 mb-8">
						<div id="detalle-prp" class="bg-white p-10 rounded-3xl shadow-sm border border-gray-50">
							<h2 class="text-2xl font-bold mb-6 flex items-center gap-3"><span class="bg-blue-50 text-[#0794ff] w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold">1</span> Regeneración con PRP</h2>
							<div class="space-y-6 text-gray-700">
								<div>
									<h3 class="font-bold text-lg mb-2 italic underline decoration-blue-100">¿Qué es el PRP?</h3>
									<p class="text-sm">El Plasma Rico en Plaquetas (PRP) es un tratamiento que utiliza componentes de la propia sangre para estimular la reparación natural.</p>
								</div>
							</div>
						</div>

						<div id="detalle-gfc" class="bg-white p-10 rounded-3xl shadow-sm border border-gray-50">
							<h2 class="text-2xl font-bold mb-6 flex items-center gap-3"><span class="bg-blue-50 text-[#0794ff] w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold">2</span> Factores de Crecimiento (GFC)</h2>
							<div class="space-y-6 text-gray-700">
								<div>
									<h3 class="font-bold text-lg mb-2 italic underline decoration-blue-100">¿Qué son los GFC?</h3>
									<p class="text-sm">Proteínas presentes en el plasma que estimulan la reparación y regeneración de los tejidos dañados.</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- 🟦 SECCIÓN 2 – TRATAMIENTOS SIN CIRUGÍA -->
			<section id="tratamientos" class="section-padding bg-white">
				<div class="container-custom">
					<div class="text-center max-w-3xl mx-auto mb-16">
						<h2 class="text-3xl md:text-4xl font-bold mb-4 text-[var(--color-text-dark)]">Tratamientos sin Cirugía</h2>
						<p class="text-gray-500">Soluciones claras y ordenadas para recuperar su calidad de vida.</p>
					</div>
					
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						<div class="p-8 bg-white border border-gray-100 rounded-2xl shadow-sm hover:shadow-xl transition-all group">
							<img src="./icon3.svg" alt="PRP" class="w-10 h-10 mb-4 object-contain icon-blue" />
							<h3 class="text-xl font-bold mb-3">Regeneración Articular con PRP</h3>
							<p class="text-sm text-gray-500 mb-6 italic">Factores de crecimiento autólogos.</p>
							<a href="#detalle-prp" class="text-[#0794ff] font-bold text-sm flex items-center gap-2 group-hover:underline">Saber más <i data-lucide="chevron-right" class="w-4 h-4 text-[#0794ff]"></i></a>
						</div>
						
						<div class="p-8 bg-white border border-gray-100 rounded-2xl shadow-sm hover:shadow-xl transition-all group">
							<img src="./icon4.svg" alt="GFC" class="w-10 h-10 mb-4 object-contain icon-blue" />
							<h3 class="text-xl font-bold mb-3">Factores de Crecimiento (GFC)</h3>
							<p class="text-sm text-gray-500 mb-6 italic">Concentración regenerativa avanzada.</p>
							<a href="#detalle-gfc" class="text-[#0794ff] font-bold text-sm flex items-center gap-2 group-hover:underline">Saber más <i data-lucide="chevron-right" class="w-4 h-4 text-[#0794ff]"></i></a>
						</div>

						<div class="p-8 bg-white border border-gray-100 rounded-2xl shadow-sm hover:shadow-xl transition-all group">
							<img src="./icon5.svg" alt="Rodilla" class="w-10 h-10 mb-4 object-contain icon-blue" />
							<h3 class="text-xl font-bold mb-3">Dolor de Rodilla sin Cirugía</h3>
							<p class="text-sm text-gray-500 mb-6 italic">Tratamiento para desgaste y lesiones.</p>
						
						</div>

						<div class="p-8 bg-white border border-gray-100 rounded-2xl shadow-sm hover:shadow-xl transition-all group">
							<img src="./icon6.svg" alt="Hombro" class="w-10 h-10 mb-4 object-contain icon-blue" />
							<h3 class="text-xl font-bold mb-3">Dolor de Hombro sin Cirugía</h3>
							<p class="text-sm text-gray-500 mb-6 italic">Recupere el rango de movimiento.</p>
							
						</div>

						<div class="p-8 bg-white border border-gray-100 rounded-2xl shadow-sm hover:shadow-xl transition-all group">
							<img src="./icon7.svg" alt="Columna" class="w-10 h-10 mb-4 object-contain icon-blue" />
							<h3 class="text-xl font-bold mb-3">Dolor de Columna sin Cirugía</h3>
							<p class="text-sm text-gray-500 mb-6 italic">Alivio para hernias y dolor lumbar.</p>
							
						</div>
					</div>
				</div>
			</section>

			

			<!-- 🟦 SECCIÓN 4 – BENEFICIOS -->
			<section class="section-padding bg-white">
				<div class="container-custom">
					<div class="text-center mb-16">
						<h2 class="text-3xl font-bold">Beneficios Claros y Concretos</h2>
					</div>
					<div class="grid grid-cols-2 lg:grid-cols-5 gap-8">
						<div class="text-center flex flex-col items-center">
							<div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4 text-center">
								<img src="./icon8.svg" alt="Beneficio" class="w-8 h-8 icon-blue" />
							</div>
							<p class="font-bold text-sm">No quirúrgico</p>
						</div>
						<div class="text-center flex flex-col items-center">
							<div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4">
								<img src="./icon9.svg" alt="Dolor" class="w-8 h-8 icon-blue" />
							</div>
							<p class="font-bold text-sm">Menor dolor</p>
						</div>
						<div class="text-center flex flex-col items-center">
							<div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4">
								<img src="./icon10.svg" alt="Recuperación" class="w-8 h-8 icon-blue" />
							</div>
							<p class="font-bold text-sm">Recuperación rápida</p>
						</div>
						<div class="text-center flex flex-col items-center">
							<div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4">
								<img src="./icon11.svg" alt="Ambulatorio" class="w-8 h-8 icon-blue" />
							</div>
							<p class="font-bold text-sm">Ambulatorio</p>
						</div>
						<div class="text-center flex flex-col items-center">
							<div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4">
								<img src="./icon12.svg" alt="Personal" class="w-8 h-8 icon-blue" />
							</div>
							<p class="font-bold text-sm">Personalizado</p>
						</div>
					</div>
				</div>
			</section>

			<!-- 🟦 SECCIÓN 5 – EL DOCTOR -->
			<section id="doctor" class="section-padding bg-[var(--color-light-bg)]">
				<div class="container-custom">
					<div class="grid lg:grid-cols-2 gap-16 items-center">
						<div class="order-2 lg:order-1">
							<!-- Ajustado a .JPG -->
							<img 
								src="./imagen2.JPG" 
								alt="Foto: Dr. Franklin Marte en Consulta" 
								class="rounded-3xl shadow-xl w-full h-[500px] object-cover bg-gray-200 block"
								loading="lazy"
							/>
						</div>
						<div class="order-1 lg:order-2">
							<span class="text-[#0794ff] font-bold uppercase text-xs tracking-widest mb-4 inline-block">Autoridad Médica</span>
							<h2 class="text-4xl font-bold mb-6 text-[var(--color-text-dark)]">Dr. Franklin Marte</h2>
							<p class="text-[#0794ff] font-bold mb-6 text-lg">Ortopeda con Enfoque en Regeneración Articular</p>
							<div class="space-y-6 text-gray-700">
								<p>Priorizamos la regeneración articular como alternativa real a la cirugía, tratando al paciente de forma integral.</p>
								<div class="border-l-4 border-[#0794ff] pl-6 italic">
									"Nuestra filosofía es ofrecer soluciones no invasivas y seguras basadas en medicina regenerativa para mejorar su calidad de vida."
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			
				<!-- 🟦 SECCIÓN 6 – UBICACIONES -->
			<section id="ubicaciones" class="section-padding bg-white">
				<div class="container-custom">
					<div class="text-center mb-16">
						<h2 class="text-3xl font-bold mb-4">Nuestras Ubicaciones</h2>
						<p class="text-gray-500 italic">Centros médicos a su disposición</p>
					</div>
					<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
						<!-- Ubicación 1: URAC -->
						<div class="flex flex-col items-center group">
							<div class="w-full aspect-video mb-4 rounded-xl overflow-hidden bg-gray-50 border border-gray-100 flex items-center justify-center p-4 group-hover:shadow-md transition-shadow">
								<img src="./imagen3.jpg" alt="Logo URAC" class="max-w-full max-h-full object-contain" loading="lazy" />
							</div>
							<h4 class="font-bold text-sm mb-1 uppercase text-[#0794ff]">URAC</h4>
							<p class="text-xs text-gray-400">Santo Domingo</p>
						</div>
						
						<!-- Ubicación 2: Padre Fantino -->
						<div class="flex flex-col items-center group">
							<div class="w-full aspect-video mb-4 rounded-xl overflow-hidden bg-gray-50 border border-gray-100 flex items-center justify-center p-4 group-hover:shadow-md transition-shadow">
								<img src="./imagen4.jpg" alt="Logo Centro Padre Fantino" class="max-w-full max-h-full object-contain" loading="lazy" />
							</div>
							<h4 class="font-bold text-sm mb-1 uppercase text-[#0794ff]">Centro Padre Fantino</h4>
							<p class="text-xs text-gray-400">La Vega</p>
						</div>

						<!-- Ubicación 3: Centro Médico Licey -->
						<div class="flex flex-col items-center group">
							<div class="w-full aspect-video mb-4 rounded-xl overflow-hidden bg-gray-50 border border-gray-100 flex items-center justify-center p-4 group-hover:shadow-md transition-shadow">
								<img src="./imagen5.jpg" alt="Logo Centro Médico Licey" class="max-w-full max-h-full object-contain" loading="lazy" />
							</div>
							<h4 class="font-bold text-sm mb-1 uppercase text-[#0794ff]">Centro Médico Licey</h4>
							<p class="text-xs text-gray-400">Santiago</p>
						</div>

						<!-- Ubicación 4: Preventis -->
						<div class="flex flex-col items-center group">
							<div class="w-full aspect-video mb-4 rounded-xl overflow-hidden bg-gray-50 border border-gray-100 flex items-center justify-center p-4 group-hover:shadow-md transition-shadow">
								<img src="./imagen6.jpg" alt="Logo Preventis" class="max-w-full max-h-full object-contain" loading="lazy" />
							</div>
							<h4 class="font-bold text-sm mb-1 uppercase text-[#0794ff]">Preventis</h4>
							<p class="text-xs text-gray-400">Santiago</p>
						</div>
					</div>
				</div>
			</section>

			<!-- 🟦 SECCIÓN 7 – AGENDA TU CONSULTA -->
            <section id="agenda" class="py-24 bg-[#0794ff] text-white relative overflow-hidden">
                <div class="container-custom relative z-10">
                    <div class="grid lg:grid-cols-2 gap-16 items-start">
                        <div class="text-left">
                            <h2 class="text-4xl md:text-5xl font-bold mb-8 italic">Agenda tu Consulta Médica</h2>
                            <p class="text-xl mb-12 opacity-90 max-w-2xl">
                                Si presentas dolor articular y deseas conocer opciones de tratamiento sin cirugía, estamos listos para evaluarte.
                            </p>
                            <div class="space-y-6">
                                <a href="https://wa.me/18099062094" target="_blank" class="inline-flex items-center justify-center gap-4 bg-[#25D366] text-white px-8 py-4 rounded-full font-bold text-lg hover:scale-105 transition-transform shadow-xl">
                                    <img src="./icon14.svg" alt="WhatsApp" class="w-6 h-6 icon-white" />
                                    WhatsApp: 809-906-2094
                                </a>
                            </div>
                        </div>

                        <!-- FORMULARIO INTEGRADO -->
                        <div class="bg-white p-8 md:p-10 rounded-[2rem] shadow-2xl text-[var(--color-text-dark)]">
                            <h3 class="text-2xl font-bold mb-6">Solicitar Información</h3>
                            <ContactForm />
                        </div>
                    </div>
                </div>
            </section>
        </main>
		
		<!-- Footer con Redes Sociales -->
		<footer class="bg-[var(--color-text-dark)] py-16 text-center text-white/40 text-sm">
			<div class="container-custom">
				<div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center mx-auto mb-6">
					<img src="./icon1-01.svg" alt="Logo" class="w-6 h-6 opacity-30 icon-blue" />
				</div>
