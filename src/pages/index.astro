<!-- SECCIÓN DE DERECHOS Y LOGOS -->
                <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-center gap-8">
                    
                    <div class="flex items-center gap-6 opacity-40 grayscale brightness-150">
                        <!-- Logo Asociación integrado -->
