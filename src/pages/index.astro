---
// Dr. Franklin Marte - Microsite de Regeneración Articular
// Estructura optimizada con extensiones JPG en mayúsculas.
import { Icon } from 'astro-icon/components'
import Instagram from '@/components/icons/Instagram.astro'
import Facebook from '@/components/icons/Facebook.astro'
import ContactForm from "../components/ContactForm.astro";
import { ClientRouter } from "astro:transitions";
import GTMConsent from "../components/GTMConsent.astro";
import WhatsApp from "@/components/WhatsApp.astro"
---



<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>

		<!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QB27T902DL"
    >
