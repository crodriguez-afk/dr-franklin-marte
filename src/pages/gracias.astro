---
// Página de Gracias - Entorno Astro
// Mantiene la línea visual del microsite del Dr. Franklin Marte
import Instagram from '@/components/icons/Instagram.astro'
import Facebook from '@/components/icons/Facebook.astro'
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>¡Gracias por contactarnos! | Dr. Franklin Marte</title>
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		
		<style>
			@import "../styles/global.css";

			.icon-blue {
				filter: invert(48%) sepia(89%) saturate(2831%) hue-rotate(188deg) brightness(101%) contrast(106%);
			}
			.icon-white {
				filter: brightness(0) invert(1);
			}
			.animate-check {
				stroke-dasharray: 100;
				stroke-dashoffset: 100;
				animation: dash 0.8s ease-in-out forwards;
			}
			@keyframes dash {
				to { stroke-dashoffset: 0; }
			}
		</style>
	</head>
	<body class="bg-slate-50 font-sans min-h-screen flex flex-col antialiased">

		<!-- Header / Logo -->
		<header class="bg-white border-b border-gray-100 py-6">
			<div class="max-w-7xl mx-auto px-4 flex justify-center">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center">
						<img src="/icon1-01.svg" alt="Logo Doctor" class="w-6 h-6 icon-blue" />
					</div>
					<div class="flex flex-col">
						<span class="font-bold text-lg leading-none uppercase tracking-tighter">Dr. Franklin Marte</span>
						<span class="text-[10px] font-bold text-[#0794ff] uppercase tracking-widest">Ortopeda Especialista</span>
					</div>
				</div>
			</div>
		</header>

		<!-- Main Content -->
		<main class="flex-grow flex items-center justify-center p-4">
			<div class="max-w-2xl w-full bg-white rounded-[2.5rem] shadow-xl shadow-blue-900/5 p-8 md:p-16 text-center border border-gray-50">
				
				<!-- Animated Check Circle -->
				<div class="w-24 h-24 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-8">
					<svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path class="animate-check" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
					</svg>
				</div>

				<h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">¡Solicitud Recibida!</h1>
				<p class="text-lg text-gray-600 mb-10 leading-relaxed">
					Gracias por confiar en nosotros. El equipo del <strong>Dr. Franklin Marte</strong> revisará tu caso y se pondrá en contacto contigo a la brevedad posible para confirmar tu cita.
				</p>

				<div class="space-y-4">
					<p class="text-sm font-bold uppercase tracking-widest text-[#0794ff]">¿Necesitas atención inmediata?</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="https://wa.me/18099062094" target="_blank" class="inline-flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 rounded-2xl font-bold text-lg hover:scale-105 transition-transform shadow-lg shadow-green-200">
							<img src="/icon14.svg" alt="WhatsApp" class="w-6 h-6 icon-white" />
							Escríbenos por WhatsApp
						</a>
						<a href="/" class="inline-flex items-center justify-center px-8 py-4 rounded-2xl font-bold text-lg text-gray-500 hover:bg-gray-50 transition-colors border border-gray-100">
							Volver al Inicio
						</a>
					</div>
				</div>

				<div class="mt-12 pt-8 border-t border-gray-100">
					<p class="text-xs text-gray-400 mb-4 uppercase tracking-widest">Síguenos en nuestras redes</p>
					<div class="flex justify-center gap-4">
						<a href="https://www.facebook.com/fmartegutierrez/?locale=es_LA" target="_blank" class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 hover:bg-[#0794ff] hover:text-white transition-all">
							<Facebook />
						</a>
						<a href="https://www.instagram.com/drmarteg/?hl=en" target="_blank" class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 hover:bg-[#0794ff] hover:text-white transition-all">
							<Instagram />
						</a>
					</div>
				</div>
			</div>
		</main>

		<!-- Footer -->
		<footer class="py-8 text-center text-gray-400 text-xs">
			<p>&copy; 2026 Dr. Franklin Marte. Todos los derechos reservados.</p>
		</footer>

		<script src="https://unpkg.com/lucide@latest"></script>
		<script is:inline>
			lucide.createIcons();
		</script>
	</body>
</html>