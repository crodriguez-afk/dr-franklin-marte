    .slide-3 { background-image: url('/imagen-fondo-3.jpg'); animation-delay: 12s; }

    @keyframes kenBurnsFade {
      0% { opacity: 0; transform: scale(1); }
      8% { opacity: 1; } /* 100% de visibilidad, sin filtros */
      30% { opacity: 1; } 
      38% { opacity: 0; }
      100% { opacity: 0; transform: scale(1.1); }
    }
