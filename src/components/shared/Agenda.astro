---
import ContactForm from "@/components/ContactForm.astro";
---

<section id="agenda" class="relative min-h-[80vh] flex items-center overflow-hidden py-24">
  
  <div class="absolute inset-0 z-0">
    <style>
      .agenda-slide {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        animation: kenBurnsAgenda 18s linear infinite;
      }
      /* Puedes usar las mismas imágenes del hero o unas nuevas de las clínicas */
      .agenda-img-1 { background-image: url('./imagen-fondo-1.jpg'); animation-delay: 0s; }
      .agenda-img-2 { background-image: url('./imagen-fondo-2.jpg'); animation-delay: 6s; }
      .agenda-img-3 { background-image: url('./imagen-fondo-3.jpg'); animation-delay: 12s; }

      @keyframes kenBurnsAgenda {
        0% { opacity: 0; transform: scale(1.1) rotate(0.02deg); }
        10% { opacity: 1; }
        33% { opacity: 1; }
        43% { opacity: 0; }
        100% { opacity: 0; transform: scale(1); }
      }
    </style>
    <div class="agenda-slide agenda-img-1"></div>
    <div class="agenda-slide agenda-img-2"></div>
    <div class="agenda-slide agenda-img-3"></div>
  </div>

  <div class="absolute inset-0 z-[1] bg-slate-950/80 backdrop-blur-[3px]"></div>

  <div class="absolute top-0 right-0 h-[500px] w-[500px] translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-600/20 blur-[120px] z-[2]"></div>
  <div class="absolute bottom-0 left-0 h-[400px] w-[400px] -translate-x-1/2 translate-y-1/2 rounded-full bg-sky-500/10 blur-[100px] z-[2]"></div>

  <div class="container-custom relative z-10">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      
      <div class="text-left">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-sky-400/30 bg-sky-500/10 px-4 py-2 text-sm font-bold text-sky-400">
          <span class="h-2 w-2 animate-pulse rounded-full bg-sky-400"></span>
          Atención inmediata
        </div>
        
        <h2 class="mb-8 text-4xl font-extrabold tracking-tight text-white md:text-5xl lg:text-6xl leading-tight">
          Agenda tu<br />
          <span class="bg-gradient-to-r from-sky-300 via-white to-blue-200 bg-clip-text text-transparent">
            consulta médica
          </span>
        </h2>
        
        <p class="mb-12 max-w-xl text-xl leading-relaxed font-medium text-slate-200">
          Si presentas dolor articular y deseas conocer opciones de
          tratamiento sin cirugía, estamos listos para evaluarte.
        </p>

        <div class="flex flex-col sm:flex-row gap-6">
          <a
            href="https://wa.me/18099062094"
            target="_blank"
            class="group inline-flex items-center justify-center gap-4 rounded-2xl bg-[#25D366] px-8 py-5 text-lg font-bold text-white shadow-xl shadow-[#25D366]/20 transition-all hover:-translate-y-1 hover:bg-[#20b858]"
          >
            <img
              src="./icon14.svg"
              alt="WhatsApp"
              class="h-7 w-7 transition-transform group-hover:rotate-12 brightness-0 invert"
            /> 
            809-906-2094
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 rounded-[3rem] bg-gradient-to-tr from-sky-500/20 to-blue-500/20 blur-2xl"></div>
        
        <div class="relative rounded-[2.5rem] border border-white/10 bg-white p-8 text-slate-800 shadow-2xl md:p-12">
          <div class="absolute top-0 right-10 h-1.5 w-20 rounded-b-full bg-sky-500"></div>
          
          <h3 class="mb-2 text-3xl font-extrabold text-slate-900">
            Solicitar Información
          </h3>
          <p class="mb-8 text-slate-500 font-medium">
            Complete el formulario y le contactaremos a la brevedad.
          </p>
          
          <ContactForm />
        </div>
      </div>

    </div>
  </div>
</section>